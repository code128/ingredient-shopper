# Serverless Database (Neon.tech PostgreSQL format)
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[ENDPOINT].aws.neon.tech/[DB_NAME]?sslmode=require"

# Google Gemini API
GEMINI_API_KEY="your_google_ai_studio_api_key_here"

# NextAuth Configuration
# You can easily generate a strong 32-character string by running: openssl rand -hex 32
AUTH_SECRET="replace_with_a_secure_randomly_generated_string"

# NextAuth Resend Provider (Magic Links)
AUTH_RESEND_KEY="re_123456789_abcdefghijklmnopqrstuvwxyz"
EMAIL_FROM="shopping-list@yourdomain.com"
